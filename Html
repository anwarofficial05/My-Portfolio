<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mohamed Anwar S — Data Analyst Portfolio</title>
<meta name="description" content="Mohamed Anwar S — Data Analytics & ML student portfolio. Power BI, Tableau, Python, SQL.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#0a0e1c;
    --panel:#111830;
    --panel-2:#161e3d;
    --grid:#28325a;
    --grid-soft:#1c2444;
    --text:#e9ecf8;
    --text-dim:#8b93b8;
    --text-faint:#5b6389;
    --query:#f0a83a;
    --query-dim:#7a5a24;
    --signal:#57c7a3;
    --signal-dim:#2c5347;
    --alert:#ff7a8a;
    --font-mono:'IBM Plex Mono', ui-monospace, monospace;
    --font-sans:'Inter', system-ui, sans-serif;
    --radius:10px;
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  @media (prefers-reduced-motion: reduce){
    html{scroll-behavior:auto;}
    *{animation-duration:0.001ms !important; animation-iteration-count:1 !important; transition-duration:0.001ms !important;}
  }
  body{
    margin:0;
    background:var(--ink);
    color:var(--text);
    font-family:var(--font-sans);
    line-height:1.5;
    -webkit-font-smoothing:antialiased;
  }
  a{color:inherit;}
  ::selection{background:var(--query-dim); color:var(--query);}

  /* background grid texture */
  body::before{
    content:"";
    position:fixed; inset:0;
    background-image:
      linear-gradient(var(--grid-soft) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-soft) 1px, transparent 1px);
    background-size:48px 48px;
    opacity:0.35;
    pointer-events:none;
    z-index:0;
  }

  .shell{
    position:relative;
    z-index:1;
    display:grid;
    grid-template-columns:240px 1fr;
    min-height:100vh;
  }

  /* ===== Sidebar ===== */
  .sidenav{
    position:sticky; top:0; height:100vh;
    border-right:1px solid var(--grid);
    background:rgba(17,24,48,0.6);
    backdrop-filter:blur(6px);
    padding:28px 20px;
    display:flex; flex-direction:column; gap:28px;
    overflow-y:auto;
  }
  .brand{
    font-family:var(--font-mono);
    font-size:13px;
    color:var(--text-dim);
  }
  .brand strong{
    display:block;
    font-size:16px;
    color:var(--text);
    letter-spacing:0.2px;
  }
  .brand .role{
    color:var(--query);
    font-size:12px;
    margin-top:4px;
    display:block;
  }
  .navlinks{display:flex; flex-direction:column; gap:2px;}
  .navlinks a{
    text-decoration:none;
    font-family:var(--font-mono);
    font-size:12.5px;
    color:var(--text-dim);
    padding:9px 10px;
    border-radius:6px;
    display:flex;
    align-items:center;
    gap:8px;
    transition:background .15s, color .15s;
  }
  .navlinks a:hover, .navlinks a:focus-visible{background:var(--panel-2); color:var(--text);}
  .navlinks a .dot{width:5px; height:5px; border-radius:50%; background:var(--text-faint); flex:none;}
  .navlinks a.active{color:var(--signal);}
  .navlinks a.active .dot{background:var(--signal);}
  .side-foot{margin-top:auto; display:flex; flex-direction:column; gap:10px;}
  .side-foot a{
    font-family:var(--font-mono); font-size:11.5px; color:var(--text-faint);
    text-decoration:none; display:flex; align-items:center; gap:6px;
  }
  .side-foot a:hover{color:var(--query);}
  .status-pill{
    font-family:var(--font-mono); font-size:11px; color:var(--signal);
    display:inline-flex; align-items:center; gap:6px;
    padding:6px 10px; border:1px solid var(--signal-dim); border-radius:20px;
    width:fit-content;
  }
  .status-pill .pulse{width:6px; height:6px; border-radius:50%; background:var(--signal); animation:pulse 1.8s infinite;}
  @keyframes pulse{0%,100%{opacity:1;} 50%{opacity:.3;}}

  /* mobile topbar */
  .topbar{display:none;}

  /* ===== Main ===== */
  main{padding:36px 44px 90px; max-width:980px;}
  .panel{
    border:1px solid var(--grid);
    background:linear-gradient(180deg, var(--panel), var(--panel) 60%, var(--panel-2));
    border-radius:var(--radius);
    margin-bottom:28px;
    overflow:hidden;
  }
  .panel-head{
    display:flex; align-items:center; justify-content:space-between;
    padding:14px 20px;
    border-bottom:1px solid var(--grid);
    font-family:var(--font-mono);
    font-size:11px;
    letter-spacing:1.5px;
    text-transform:uppercase;
    color:var(--text-faint);
  }
  .panel-head .lamp{width:7px; height:7px; border-radius:50%; background:var(--grid); margin-right:8px;}
  .panel-head .lamp.on{background:var(--signal); box-shadow:0 0 8px var(--signal);}
  .panel-head-left{display:flex; align-items:center;}
  .panel-body{padding:26px 24px;}

  h1,h2,h3{font-family:var(--font-sans); margin:0;}
  .section-title{font-size:22px; font-weight:800; margin-bottom:6px;}
  .section-sub{color:var(--text-dim); font-size:14.5px; margin-bottom:20px;}

  /* ===== Hero / Query Console ===== */
  .hero-panel .panel-body{padding:30px 24px 34px;}
  .console{
    font-family:var(--font-mono);
    background:#070a15;
    border:1px solid var(--grid);
    border-radius:8px;
    padding:20px 22px;
    font-size:13.5px;
    color:var(--text-dim);
    overflow-x:auto;
  }
  .console .prompt{color:var(--signal);}
  .console .kw{color:var(--query);}
  .console .str{color:#9fd7ff;}
  .console .cursor{display:inline-block; width:8px; height:15px; background:var(--query); vertical-align:middle; animation:blink 1s step-end infinite;}
  @keyframes blink{50%{opacity:0;}}
  #queryLine{white-space:pre;}

  .hero-title{
    font-size:clamp(28px, 4vw, 40px);
    font-weight:800;
    margin:22px 0 6px;
    letter-spacing:-0.5px;
  }
  .hero-title .accent{color:var(--query);}
  .hero-sub{color:var(--text-dim); font-size:16px; max-width:640px; margin-bottom:22px;}
  .hero-loc{font-family:var(--font-mono); font-size:12px; color:var(--text-faint); margin-bottom:26px;}

  .kpi-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit, minmax(140px, 1fr));
    gap:14px;
  }
  .kpi{
    border:1px solid var(--grid);
    background:var(--panel-2);
    border-radius:8px;
    padding:16px 16px 14px;
    opacity:0; transform:translateY(8px);
    animation:riseIn .5s ease forwards;
  }
  .kpi .val{font-family:var(--font-mono); font-size:26px; font-weight:700; color:var(--signal);}
  .kpi .lbl{font-size:11.5px; color:var(--text-faint); text-transform:uppercase; letter-spacing:1px; margin-top:4px;}
  @keyframes riseIn{to{opacity:1; transform:translateY(0);}}

  .hero-cta{display:flex; gap:12px; margin-top:24px; flex-wrap:wrap;}
  .btn{
    font-family:var(--font-mono); font-size:13px;
    padding:11px 18px; border-radius:7px;
    text-decoration:none; display:inline-flex; align-items:center; gap:8px;
    border:1px solid var(--grid); transition:all .15s;
  }
  .btn.primary{background:var(--query); color:#1a1200; border-color:var(--query); font-weight:600;}
  .btn.primary:hover{filter:brightness(1.08);}
  .btn.ghost{color:var(--text); background:transparent;}
  .btn.ghost:hover{border-color:var(--signal); color:var(--signal);}

  /* ===== About ===== */
  .about-grid{display:grid; grid-template-columns:1.4fr 1fr; gap:28px;}
  .soft-list{list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:9px;}
  .soft-list li{
    font-size:13.5px; color:var(--text-dim);
    display:flex; align-items:center; gap:9px;
  }
  .soft-list li::before{content:"›"; color:var(--query); font-weight:700;}

  /* ===== Skills matrix ===== */
  .matrix{display:grid; grid-template-columns:repeat(auto-fit, minmax(230px,1fr)); gap:16px;}
  .matrix-card{border:1px solid var(--grid); border-radius:8px; padding:16px 16px 14px; background:var(--panel-2);}
  .matrix-card h4{
    font-family:var(--font-mono); font-size:11.5px; text-transform:uppercase;
    letter-spacing:1px; color:var(--signal); margin:0 0 12px;
  }
  .tag-row{display:flex; flex-wrap:wrap; gap:7px;}
  .tag{
    font-family:var(--font-mono); font-size:11.5px;
    padding:5px 9px; border-radius:5px;
    background:var(--panel); border:1px solid var(--grid);
    color:var(--text-dim);
  }

  /* ===== Timeline ===== */
  .timeline{position:relative; padding-left:24px;}
  .timeline::before{content:""; position:absolute; left:5px; top:6px; bottom:6px; width:1px; background:var(--grid);}
  .tl-item{position:relative; padding-bottom:26px;}
  .tl-item:last-child{padding-bottom:0;}
  .tl-item::before{
    content:""; position:absolute; left:-24px; top:4px;
    width:11px; height:11px; border-radius:50%;
    background:var(--ink); border:2px solid var(--signal);
  }
  .tl-date{font-family:var(--font-mono); font-size:11px; color:var(--query); text-transform:uppercase; letter-spacing:.5px;}
  .tl-role{font-size:16px; font-weight:700; margin:4px 0 2px;}
  .tl-org{color:var(--text-dim); font-size:13.5px;}

  /* ===== Projects ===== */
  .proj-grid{display:grid; grid-template-columns:repeat(auto-fit, minmax(260px,1fr)); gap:16px;}
  .proj-card{
    border:1px solid var(--grid); border-radius:8px; background:var(--panel-2);
    padding:18px; display:flex; flex-direction:column; gap:10px;
  }
  .proj-head{display:flex; align-items:center; justify-content:space-between; gap:10px;}
  .proj-title{font-size:15px; font-weight:700;}
  .proj-tags{display:flex; flex-wrap:wrap; gap:6px;}
  .proj-desc{font-size:13px; color:var(--text-dim); margin:0; padding-left:16px;}
  .proj-desc li{margin-bottom:5px;}

  /* ===== Certifications ===== */
  .cert-toolbar{
    display:flex; align-items:center; justify-content:space-between; gap:12px;
    margin-bottom:18px; flex-wrap:wrap;
  }
  .cert-search{
    font-family:var(--font-mono); font-size:12.5px;
    background:var(--panel-2); border:1px solid var(--grid); color:var(--text);
    border-radius:6px; padding:9px 12px; flex:1; min-width:180px;
  }
  .cert-search:focus-visible{outline:2px solid var(--signal); outline-offset:1px;}
  .cert-count{font-family:var(--font-mono); font-size:11.5px; color:var(--text-faint); white-space:nowrap;}
  .cert-log{display:flex; flex-direction:column; gap:1px; border:1px solid var(--grid); border-radius:8px; overflow:hidden;}
  .cert-row{
    display:grid; grid-template-columns:1fr auto auto;
    align-items:center; gap:14px;
    background:var(--panel-2); padding:12px 16px;
    border-bottom:1px solid var(--grid);
  }
  .cert-row:last-child{border-bottom:none;}
  .cert-name{font-size:13.5px; font-weight:600;}
  .cert-issuer{font-family:var(--font-mono); font-size:11px; color:var(--text-faint);}
  .cert-year{font-family:var(--font-mono); font-size:11.5px; color:var(--query); text-align:right;}
  .cert-link{font-family:var(--font-mono); font-size:11px; color:var(--signal); text-decoration:none; white-space:nowrap;}
  .cert-link:hover{text-decoration:underline;}
  .cert-empty{padding:24px; text-align:center; color:var(--text-faint); font-family:var(--font-mono); font-size:12.5px;}

  .admin-trigger{
    font-family:var(--font-mono); font-size:11px; color:var(--text-faint);
    background:none; border:1px dashed var(--grid); border-radius:6px;
    padding:8px 12px; cursor:pointer; transition:border-color .15s, color .15s;
  }
  .admin-trigger:hover{border-color:var(--query); color:var(--query);}

  /* ===== Contact ===== */
  .contact-grid{display:grid; grid-template-columns:repeat(auto-fit, minmax(200px,1fr)); gap:14px;}
  .contact-card{
    border:1px solid var(--grid); border-radius:8px; padding:16px;
    background:var(--panel-2); text-decoration:none; display:flex; flex-direction:column; gap:6px;
    transition:border-color .15s;
  }
  .contact-card:hover{border-color:var(--signal);}
  .contact-card .k{font-family:var(--font-mono); font-size:10.5px; text-transform:uppercase; letter-spacing:1px; color:var(--text-faint);}
  .contact-card .v{font-size:14px; font-weight:600; word-break:break-word;}

  footer{
    text-align:center; padding:30px 20px 50px;
    font-family:var(--font-mono); font-size:11px; color:var(--text-faint);
  }

  /* ===== Modal ===== */
  .modal-backdrop{
    position:fixed; inset:0; background:rgba(4,6,14,0.75);
    display:none; align-items:flex-start; justify-content:center;
    padding:5vh 16px; z-index:50; overflow-y:auto;
  }
  .modal-backdrop.open{display:flex;}
  .modal{
    background:var(--panel); border:1px solid var(--grid); border-radius:var(--radius);
    width:100%; max-width:560px; margin-bottom:5vh;
  }
  .modal-head{
    display:flex; align-items:center; justify-content:space-between;
    padding:16px 20px; border-bottom:1px solid var(--grid);
  }
  .modal-head h3{font-size:15px; font-family:var(--font-mono); text-transform:uppercase; letter-spacing:1px; color:var(--signal);}
  .modal-close{background:none; border:none; color:var(--text-faint); font-size:20px; cursor:pointer; line-height:1;}
  .modal-close:hover{color:var(--alert);}
  .modal-body{padding:20px;}
  .field{margin-bottom:14px;}
  .field label{display:block; font-family:var(--font-mono); font-size:11px; color:var(--text-dim); margin-bottom:6px; text-transform:uppercase; letter-spacing:.5px;}
  .field input{
    width:100%; background:var(--panel-2); border:1px solid var(--grid); color:var(--text);
    padding:10px 12px; border-radius:6px; font-family:var(--font-sans); font-size:13.5px;
  }
  .field input:focus-visible{outline:2px solid var(--signal); outline-offset:1px;}
  .field-row{display:grid; grid-template-columns:1fr 1fr; gap:12px;}
  .modal-note{
    font-size:12.5px; color:var(--text-dim); background:var(--panel-2);
    border:1px solid var(--grid); border-radius:6px; padding:12px 14px; margin-bottom:16px; line-height:1.6;
  }
  .modal-note strong{color:var(--query);}
  .modal-actions{display:flex; gap:10px; flex-wrap:wrap; margin-top:6px;}
  .modal-actions .btn{cursor:pointer; font-family:var(--font-mono); font-size:12.5px; border:1px solid var(--grid); background:transparent; color:var(--text);}
  .modal-list{margin-top:20px; border-top:1px solid var(--grid); padding-top:16px;}
  .modal-list-item{
    display:flex; align-items:center; justify-content:space-between; gap:10px;
    font-size:12.5px; padding:8px 0; border-bottom:1px solid var(--grid-soft);
  }
  .modal-list-item button{
    background:none; border:none; color:var(--alert); cursor:pointer; font-family:var(--font-mono); font-size:11px;
  }
  .toast{
    position:fixed; bottom:24px; left:50%; transform:translateX(-50%) translateY(20px);
    background:var(--signal); color:#052018; font-family:var(--font-mono); font-size:12.5px;
    padding:11px 18px; border-radius:7px; opacity:0; pointer-events:none;
    transition:all .25s; z-index:60; font-weight:600;
  }
  .toast.show{opacity:1; transform:translateX(-50%) translateY(0);}

  /* ===== Responsive ===== */
  @media (max-width: 860px){
    .shell{grid-template-columns:1fr;}
    .sidenav{display:none;}
    .topbar{
      display:flex; align-items:center; justify-content:space-between;
      padding:16px 18px; border-bottom:1px solid var(--grid);
      background:rgba(17,24,48,0.85); backdrop-filter:blur(6px);
      position:sticky; top:0; z-index:20;
    }
    .topbar .brand{font-size:12px;}
    .topbar .brand strong{font-size:14px;}
    .hamburger{
      background:none; border:1px solid var(--grid); border-radius:6px;
      width:38px; height:38px; color:var(--text); font-size:16px; cursor:pointer;
    }
    .mobile-nav{
      display:none; flex-direction:column; gap:2px; padding:14px 18px;
      border-bottom:1px solid var(--grid); background:var(--panel);
    }
    .mobile-nav.open{display:flex;}
    .mobile-nav a{
      font-family:var(--font-mono); font-size:13px; color:var(--text-dim);
      text-decoration:none; padding:10px 6px; border-bottom:1px solid var(--grid-soft);
    }
    main{padding:24px 16px 60px;}
    .about-grid{grid-template-columns:1fr;}
    .cert-row{grid-template-columns:1fr; row-gap:6px;}
    .cert-year{text-align:left;}
    .field-row{grid-template-columns:1fr;}
  }
</style>
</head>
