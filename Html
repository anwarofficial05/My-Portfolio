<div class="modal-backdrop" id="adminBackdrop">
  <div class="modal">
    <div class="modal-head">
      <h3>Manage Certification Log</h3>
      <button class="modal-close" id="closeAdminBtn" aria-label="Close">×</button>
    </div>
    <div class="modal-body">
      <div class="modal-note">
        <strong>How this works:</strong> the site reads certifications from a separate <code>certificates.json</code> file at runtime — not from this HTML file. Add an entry below, then click <strong>"Download updated certificates.json"</strong> and replace that file in your GitHub repo (or wherever you host this site). The page will pick it up automatically on next load — no code changes needed, ever.
      </div>

      <div class="field">
        <label for="fCertName">Certification name</label>
        <input type="text" id="fCertName" placeholder="e.g. Google Data Analytics Certificate">
      </div>
      <div class="field-row">
        <div class="field">
          <label for="fCertIssuer">Issuer</label>
          <input type="text" id="fCertIssuer" placeholder="e.g. Google / Coursera">
        </div>
        <div class="field">
          <label for="fCertYear">Year (optional)</label>
          <input type="text" id="fCertYear" placeholder="e.g. 2026">
        </div>
      </div>
      <div class="field">
        <label for="fCertUrl">Credential URL (optional)</label>
        <input type="text" id="fCertUrl" placeholder="https://…">
      </div>

      <div class="modal-actions">
        <button class="btn" id="addCertBtn">+ Add to log</button>
        <button class="btn" id="downloadJsonBtn">⬇ Download updated certificates.json</button>
        <button class="btn" id="copyJsonBtn">⧉ Copy JSON</button>
      </div>

      <div class="modal-list" id="adminCertList"></div>
    </div>
  </div>
