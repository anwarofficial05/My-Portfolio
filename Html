<div class="toast" id="toast"></div>

<script>
(function(){
  document.getElementById('year').textContent = new Date().getFullYear();

  /* ---------- Mobile nav ---------- */
  var hamburgerBtn = document.getElementById('hamburgerBtn');
  var mobileNav = document.getElementById('mobileNav');
  hamburgerBtn.addEventListener('click', function(){
    var isOpen = mobileNav.classList.toggle('open');
    hamburgerBtn.setAttribute('aria-expanded', isOpen);
  });
  document.querySelectorAll('.mobile-nav a').forEach(function(a){
    a.addEventListener('click', function(){ mobileNav.classList.remove('open'); });
  });

  /* ---------- Active section highlight ---------- */
  var navLinks = document.querySelectorAll('#navlinks a');
  var sections = Array.prototype.slice.call(document.querySelectorAll('main section'));
  function onScroll(){
    var pos = window.scrollY + 140;
    var current = sections[0] && sections[0].id;
    sections.forEach(function(s){ if (pos >= s.offsetTop) current = s.id; });
    navLinks.forEach(function(a){
      a.classList.toggle('active', a.getAttribute('href') === '#' + current);
    });
  }
  window.addEventListener('scroll', onScroll, {passive:true});
  onScroll();

  /* ---------- Hero query typing animation ---------- */
  var queryText = "SELECT insights FROM mohamed_anwar WHERE role = 'Data Analyst' AND ready = true;";
  var queryEl = document.getElementById('queryLine');
  var i = 0;
  function typeQuery(){
    if (i <= queryText.length){
      var display = queryText.slice(0, i)
        .replace(/\b(SELECT|FROM|WHERE|AND)\b/g, '<span class="kw">$1</span>')
        .replace(/('[^']*')/g, '<span class="str">$1</span>');
      queryEl.innerHTML = display;
      i++;
      setTimeout(typeQuery, 22);
    }
  }
  typeQuery();

  /* ---------- Projects data ---------- */
  var PROJECTS = [
    {
      title:"E-Commerce Sales Analysis",
      tags:["Python","Power BI"],
      points:[
        "Analyzed and visualized e-commerce sales data — data cleaning, KPI tracking, and sales trend analysis.",
        "Built dashboards and surfaced business insights through 6+ visualizations and data-driven recommendations."
      ]
    },
    {
      title:"Student Performance Analysis",
      tags:["Python"],
      points:[
        "Explored student performance data to identify key academic factors and at-risk student groups.",
        "Created visualizations, ran segmentation analysis, and delivered actionable recommendations."
      ]
    },
    {
      title:"Responsive Portfolio Website",
      tags:["HTML","CSS","JavaScript"],
      points:[
        "Built a responsive personal portfolio website to showcase skills and projects."
      ]
    },
    {
      title:"User Authentication System",
      tags:["HTML","CSS","JavaScript"],
      points:[
        "Built a responsive, simple user authentication system using front-end technologies."
      ]
    },
    {
      title:"Voice Assistant (Python)",
      tags:["Python","Speech Recognition"],
      points:[
        "Built a Python-based voice assistant with 30+ voice commands for speech recognition, automation, web search, and productivity tasks."
      ]
    }
  ];
  var projGrid = document.getElementById('projGrid');
  PROJECTS.forEach(function(p){
    var card = document.createElement('div');
    card.className = 'proj-card';
    card.innerHTML =
      '<div class="proj-head"><span class="proj-title">'+escapeHtml(p.title)+'</span></div>'+
      '<div class="proj-tags">'+ p.tags.map(function(t){return '<span class="tag">'+escapeHtml(t)+'</span>';}).join('') +'</div>'+
      '<ul class="proj-desc">'+ p.points.map(function(pt){return '<li>'+escapeHtml(pt)+'</li>';}).join('') +'</ul>';
    projGrid.appendChild(card);
  });

  /* ---------- Certifications: loaded from certificates.json, editable post-deploy ---------- */
  var DEFAULT_CERTS = [
    {name:"Deloitte Data Analytics Job Simulation", issuer:"Deloitte", year:"", url:""},
    {name:"Deloitte Cyber Job Simulation", issuer:"Deloitte", year:"", url:""},
    {name:"Tata GenAI Powered Data Analytics Job Simulation", issuer:"Tata", year:"", url:""},
    {name:"Tata Data Visualisation: Empowering Business with Effective Insights", issuer:"Tata", year:"", url:""},
    {name:"Power BI Workshop Certification", issuer:"", year:"", url:""},
    {name:"Big Data Certification", issuer:"Infosys Springboard", year:"", url:""},
    {name:"Scala Programming", issuer:"Infosys Springboard", year:"", url:""},
    {name:"Claude Certification", issuer:"Anthropic", year:"", url:""},
    {name:"Claude Cowork Certification", issuer:"Anthropic", year:"", url:""},
    {name:"Claude Code Certification", issuer:"Anthropic", year:"", url:""},
    {name:"AI Fluency Certification", issuer:"Anthropic", year:"", url:""},
    {name:"Claude Platform Certification", issuer:"Anthropic", year:"", url:""},
    {name:"Agentic AI Mastery", issuer:"Infosys Springboard", year:"", url:""},
    {name:"SQL Case Study - SQL Workshop", issuer:"Infosys Springboard", year:"", url:""},
    {name:"SAP Certification", issuer:"SAP", year:"", url:""},
    {name:"Microsoft Badges", issuer:"Microsoft", year:"", url:""},
    {name:"TCS iON Master Data Management Certificate", issuer:"TCS iON", year:"", url:""},
    {name:"NVIDIA AI Certificate", issuer:"NVIDIA", year:"", url:""}
  ];

  var currentCerts = [];

  function escapeHtml(s){
    return String(s == null ? '' : s)
      .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function renderCerts(list){
    var log = document.getElementById('certLog');
    var countEl = document.getElementById('certCount');
    var kpiEl = document.getElementById('certKpi');
    kpiEl.textContent = currentCerts.length + (currentCerts.length ? '+' : '');
    countEl.textContent = list.length + ' entr' + (list.length === 1 ? 'y' : 'ies');
    if (!list.length){
      log.innerHTML = '<div class="cert-empty">No certifications match that search.</div>';
      return;
    }
    log.innerHTML = list.map(function(c){
      return '<div class="cert-row">' +
        '<div><div class="cert-name">'+escapeHtml(c.name)+'</div>' +
          (c.issuer ? '<div class="cert-issuer">'+escapeHtml(c.issuer)+'</div>' : '') + '</div>' +
        '<div class="cert-year">'+escapeHtml(c.year || '—')+'</div>' +
        (c.url ? '<a class="cert-link" href="'+escapeHtml(c.url)+'" target="_blank" rel="noopener">View ↗</a>' : '<span></span>') +
      '</div>';
    }).join('');
  }

  function loadCerts(){
    fetch('./certificates.json', {cache:'no-store'})
      .then(function(r){ if(!r.ok) throw new Error('no file'); return r.json(); })
      .then(function(data){
        currentCerts = Array.isArray(data) ? data : DEFAULT_CERTS;
        renderCerts(currentCerts);
        renderAdminList();
      })
      .catch(function(){
        // certificates.json not found (e.g. opened locally, or not yet uploaded) — use built-in defaults
        currentCerts = DEFAULT_CERTS.slice();
        renderCerts(currentCerts);
        renderAdminList();
      });
  }
  loadCerts();

  document.getElementById('certSearch').addEventListener('input', function(e){
    var q = e.target.value.trim().toLowerCase();
    var filtered = currentCerts.filter(function(c){
      return (c.name||'').toLowerCase().indexOf(q) !== -1 || (c.issuer||'').toLowerCase().indexOf(q) !== -1;
    });
    renderCerts(filtered);
  });

  /* ---------- Admin modal ---------- */
  var backdrop = document.getElementById('adminBackdrop');
  document.getElementById('openAdminBtn').addEventListener('click', function(){
    backdrop.classList.add('open');
    renderAdminList();
  });
  document.getElementById('closeAdminBtn').addEventListener('click', function(){
    backdrop.classList.remove('open');
  });
  backdrop.addEventListener('click', function(e){
    if (e.target === backdrop) backdrop.classList.remove('open');
  });

  function renderAdminList(){
    var box = document.getElementById('adminCertList');
    if (!currentCerts.length){
      box.innerHTML = '<div class="cert-empty">Log is empty.</div>';
      return;
    }
    box.innerHTML = currentCerts.map(function(c, idx){
      return '<div class="modal-list-item"><span>'+escapeHtml(c.name)+(c.issuer ? ' — '+escapeHtml(c.issuer) : '')+'</span>' +
        '<button data-idx="'+idx+'" class="removeCertBtn">remove</button></div>';
    }).join('');
    box.querySelectorAll('.removeCertBtn').forEach(function(btn){
      btn.addEventListener('click', function(){
        currentCerts.splice(parseInt(btn.getAttribute('data-idx'),10), 1);
        renderAdminList();
        renderCerts(currentCerts);
        showToast('Removed. Download the JSON to save this change.');
      });
    });
  }

  document.getElementById('addCertBtn').addEventListener('click', function(){
    var name = document.getElementById('fCertName').value.trim();
    if (!name){ showToast('Enter a certification name first.'); return; }
    var entry = {
      name:name,
      issuer:document.getElementById('fCertIssuer').value.trim(),
      year:document.getElementById('fCertYear').value.trim(),
      url:document.getElementById('fCertUrl').value.trim()
    };
    currentCerts.unshift(entry);
    document.getElementById('fCertName').value = '';
    document.getElementById('fCertIssuer').value = '';
    document.getElementById('fCertYear').value = '';
    document.getElementById('fCertUrl').value = '';
    renderAdminList();
    renderCerts(currentCerts);
    showToast('Added — now download the updated file below.');
  });

  document.getElementById('downloadJsonBtn').addEventListener('click', function(){
    var blob = new Blob([JSON.stringify(currentCerts, null, 2)], {type:'application/json'});
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url; a.download = 'certificates.json';
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    URL.revokeObjectURL(url);
    showToast('Downloaded — replace certificates.json in your repo.');
  });

  document.getElementById('copyJsonBtn').addEventListener('click', function(){
    var text = JSON.stringify(currentCerts, null, 2);
    if (navigator.clipboard && navigator.clipboard.writeText){
      navigator.clipboard.writeText(text).then(function(){ showToast('JSON copied to clipboard.'); });
    } else {
      showToast('Copy not supported in this browser — use Download instead.');
    }
  });

  var toastTimer;
  function showToast(msg){
    var t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(function(){ t.classList.remove('show'); }, 2800);
  }
})();
</script>
